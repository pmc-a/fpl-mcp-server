{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "env": {
    "node": true,
    "es2022": true
  },
  "rules": {
    "no-unused-vars": "off",
    "typescript/no-unused-vars": "error",
    "typescript/no-explicit-any": "warn"
  },
  "ignorePatterns": ["dist/**", "node_modules/**"],
  "options": {
    "typeAware": true
  }
}
